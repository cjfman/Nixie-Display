sequence|end
sequence|start|crash_6
frame|1|> {4}<
frame|1| {1}> {2}<
frame|1| {2}x
sequence|insert|x_spin_2|shift=2|repeat=2|scale=1
sequence|end
sequence|start|crash_4
frame|1|>  <
frame|1| x
sequence|insert|x_spin_2|shift=1|repeat=2|scale=1
sequence|end

